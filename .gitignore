# Binaries and build output
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
bin/
dist/
build/
assassin-android-controller

# cmd/server/dist 是 //go:embed 的目标目录：dev 时只有 .gitkeep 占位，
# build 阶段才会临时把 web/dist 拷过来。这里反向放行 .gitkeep，让它能进版本库，
# 但仍然忽略其它一切真实构建产物。
!cmd/server/dist/
cmd/server/dist/*
!cmd/server/dist/.gitkeep

# Coverage and profiling
*.coverprofile
coverage.out
cover.out
cpu.out
mem.out

# Go workspace and vendoring (optional in many projects)
go.work
go.work.sum

# Dependency directories (uncomment if you do not commit vendor/)
# vendor/

# Environment and local config
.env
.env.*
*.local

# Logs
*.log
logs/

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

**/__debug_bin*

/docs/*
/temp*
/output*
/data
/.tmp
